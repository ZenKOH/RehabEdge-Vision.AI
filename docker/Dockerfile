FROM python:3.12-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 libgl1 git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . /app
RUN python -m pip install --upgrade pip && python -m pip install -e .[vision]

CMD ["rehabedge", "dashboard", "--events", "events.csv", "--host", "0.0.0.0", "--port", "8000"]
